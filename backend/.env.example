# ========== MQTT CONFIGURATION ==========
# HiveMQ Cloud Broker
MQTT_BROKER=mqtts://c35e052ade714fca9ddce72e63df4c3e.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=admin
MQTT_PASSWORD=Admin123

# Tópico que o ESP32 publica
MQTT_TOPIC=manutai/leitura

# ========== DATABASE CONFIGURATION ==========
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=manutai
DB_PORT=3306
DB_DIALECT=mysql

# ========== SERVER CONFIGURATION ==========
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# ========== EMAIL CONFIGURATION ==========
# Use uma Senha de App do Google (não a senha normal da conta):
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_de_app_gmail

# ========== SENSOR CONFIGURATION ==========
# Intervalos de alerta padrão
SENSOR_1_TEMP_MIN=15
SENSOR_1_TEMP_MAX=30
SENSOR_1_UMIDADE_MIN=40
SENSOR_1_UMIDADE_MAX=70
