# ==============================
# BANCO DE DADOS
# ==============================
# Para testes com SQLite:
#DB_DIALECT=sqlite
#DB_STORAGE=./database.sqlite

# Para produção com MySQL (Railway):
DB_DIALECT=mysql
DB_HOST=seu-host.proxy.rlwy.net
DB_PORT=0000
DB_USER=root
DB_PASSWORD=sua_senha_mysql_aqui
DB_NAME=railway

# ==============================
# AUTENTICAÇÃO JWT
# ==============================
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=gere_uma_chave_forte_aqui

# ==============================
# MQTT (HiveMQ Cloud)
# ==============================
MQTT_BROKER=mqtts://seu-broker-id.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=seu_usuario_mqtt
MQTT_PASSWORD=sua_senha_mqtt
MQTT_TOPIC=manutai/leitura

# ==============================
# SERVIDOR
# ==============================
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3001

# ==============================
# EMAIL (Nodemailer)
# ==============================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
# Gere uma senha de app em: https://myaccount.google.com/apppasswords
EMAIL_PASS=sua_senha_de_app_aqui

# ==============================
# GROQ IA (ChatBot)
# ==============================
# Gere sua chave em: https://console.groq.com/keys
GROQ_API_KEY=sua_chave_groq_aqui
GROQ_MODEL=llama-3.3-70b-versatile
